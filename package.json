{
  "name": "aelauncher",
  "private": true,
  "version": "0.1.0",
  "author": {
    "name": "Naufal",
    "email": "naufal@example.com"
  },
  "description": "AELauncher - A modern launcher for apps and games.",
  "main": "electron/main.js",
  "build": {
    "appId": "com.aelauncher.app",
    "productName": "AELauncher",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "category": "Game"
    }
  },
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "vite": "vite",
    "electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder --publish never",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  }
}